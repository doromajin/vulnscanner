# VulnScanner 夜間改善ループ 環境変数テンプレート
# このファイルをコピーして .env にリネームし、値を設定してください。
# .env は .gitignore に登録済みのためコミットされません。

# 必須: FuguAI API キー
FUGU_API_KEY=your-fugu-api-key-here

# 省略可: FuguAI エンドポイント (デフォルト: https://api.fugu.sakana.ai/v1)
# FUGU_API_BASE=https://api.fugu.sakana.ai/v1

# 省略可: FuguAI モデル名 (デフォルト: fugu-chat)
# FUGU_MODEL=fugu-chat
