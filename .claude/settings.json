{
  "permissions": {
    "allow": [
      "Bash(python*)",
      "Bash(pytest*)",
      "Bash(vulnscan*)",
      "Bash(git add*)",
      "Bash(git commit*)",
      "Bash(git status*)",
      "Bash(git log*)",
      "Bash(git diff*)",
      "Bash(git branch*)",
      "Bash(git show*)",
      "Bash(git mv*)",
      "Bash(git apply*)",
      "Bash(git clone*)",
      "Bash(git push*)",
      "PowerShell(git push*)",
      "Bash(cat*)",
      "Bash(ls*)",
      "Bash(echo*)",
      "Bash(grep*)",
      "Bash(head*)",
      "Bash(tail*)",
      "Bash(wc*)",
      "Bash(pip list*)",
      "Bash(pip show*)",
      "Bash(pip freeze*)",
      "Bash(pip check*)",
      "PowerShell(python*)",
      "PowerShell(pytest*)",
      "PowerShell(vulnscan*)",
      "PowerShell(git add*)",
      "PowerShell(git commit*)",
      "PowerShell(git status*)",
      "PowerShell(git log*)",
      "PowerShell(git diff*)",
      "PowerShell(git branch*)",
      "PowerShell(git show*)",
      "PowerShell(Get-ChildItem*)",
      "PowerShell(Get-Content*)",
      "PowerShell(Select-Object*)",
      "PowerShell(Where-Object*)",
      "PowerShell(Sort-Object*)",
      "PowerShell(ForEach-Object*)",
      "PowerShell(Measure-Object*)"
    ],
    "deny": [
      "Bash(rm*)",
      "Bash(curl*)",
      "Bash(wget*)",
      "PowerShell(Remove-Item*)",
      "PowerShell(New-Item*)",
      "PowerShell(Set-Content*)",
      "PowerShell(Out-File*)",
      "PowerShell(Copy-Item*)",
      "PowerShell(Move-Item*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "shell": "bash",
            "command": "python -c \"import sys,json; d=json.load(sys.stdin); sys.stderr.write('[自動実行] $ ' + d['tool_input']['command'] + '\\n')\" 2>/dev/null || true"
          },
          {
            "type": "command",
            "shell": "bash",
            "command": "python C:/VulnScanner/.claude/notify_hook.py pre"
          }
        ]
      },
      {
        "matcher": "PowerShell",
        "hooks": [
          {
            "type": "command",
            "shell": "bash",
            "command": "python C:/VulnScanner/.claude/notify_hook.py pre"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "shell": "bash",
            "command": "python C:/VulnScanner/.claude/notify_hook.py post"
          }
        ]
      },
      {
        "matcher": "PowerShell",
        "hooks": [
          {
            "type": "command",
            "shell": "bash",
            "command": "python C:/VulnScanner/.claude/notify_hook.py post"
          }
        ]
      }
    ]
  }
}
